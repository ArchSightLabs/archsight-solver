      "mcp": {
        "tool": "calculate",
        "argumentsWrapper": "将 asmsJson 作为 arguments.payload 传入"
      },
      "benchmark": {
        "tool": "benchmark_case_run",
        "caseId": "frame-portal-benchmark",
        "purpose": "用同类门式刚架标准算例复核节点数量、构件数量和整体求解状态。"
      },
      "export": {
        "endpoint": "/api/export",
        "format": "docx",
        "payloadOverlay": {
          "format": "docx"
        }
