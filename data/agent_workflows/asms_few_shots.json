              "x": 6,
              "y": 4,
              "supportType": "free"
            }
          ],
          "members": [
            {
              "id": "C1",
              "start": "N1",
              "end": "N3",
              "E_GPa": 210,
              "A_cm2": 240,
              "I_cm4": 12000,
              "kind": "column"
            },
            {
              "id": "B1",
              "start": "N3",
              "end": "N4",
              "E_GPa": 210,
              "A_cm2": 220,
