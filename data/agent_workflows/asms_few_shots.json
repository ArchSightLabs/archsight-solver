{
  "schemaVersion": 1,
  "updatedAt": "2026-05-28",
  "title": "ArchSight Solver Agent 工程流 ASMS-JSON Few-shot 样例",
  "scope": "自然语言工况到 ASMS-JSON、REST/CLI/MCP 调用、公开验证集复核和计算书导出的最小可执行样例。",
  "positioning": "本文件是 ASMS-JSON 的可测试样例库，不是普通静态示例。每条样例同时服务 Agent few-shot、CLI/MCP 调用模板、benchmark 引用、计算书导出验证和回归测试。",
  "contractMessage": "ASMS-JSON 是入口，JSON Schema 是契约，benchmark 是证据，REST/CLI/MCP 是同源执行面。",
  "boundary": "所有样例仅用于线弹性静力求解、教学演示、方案阶段复核和自动化集成验证，不替代工程签审、规范设计或施工安全判断。",
  "sharedFlow": [
    "从自然语言工况中抽取结构类型、几何、材料截面、支座、荷载和输出指标。",
    "生成 ASMS-JSON，并在缺少关键工程输入时停止请求补充，不用经验默认值静默补齐。",
    "通过 REST/CLI/MCP 的 calculate 工具执行确定性求解。",
    "用 benchmark_case_run 对同类公开验证集做回归复核，并记录 caseId、状态、误差检查和工具版本；catalog 级 schemaVersion 来自 benchmark catalog 元数据。",
    "需要归档时调用 /api/export 生成 WORD 或 XLSX 计算书，计算书结论仍需工程师复核。"
  ],
  "examples": [
    {
      "id": "agent-beam-simple-uniform",
      "analysisType": "beam",
      "naturalLanguage": "复核一根 6 m 简支钢梁，全跨向下均布荷载 12 kN/m，弹性模量 206 GPa，截面惯性矩 85000 cm^4，输出最大挠度、最大弯矩、最大剪力和支座反力，并生成可归档计算书。",
      "missingInputPolicy": "若缺少跨度、边界、E、I 或荷载幅值，Agent 必须先要求补充，不得自行套用默认截面。",
      "asmsJson": {
        "analysisType": "beam",
        "projectName": "Agent 简支梁均布荷载复核",
        "beamType": "simply_supported",
        "loadType": "uniform",
        "spans": [
          6
        ],
        "E": 206,
        "I": 85000,
        "q": 12
      },
      "cli": {
        "tool": "calculate",
        "inputWrapper": "将 asmsJson 包装为 {\"payload\": asmsJson}",
        "command": "python -m backend.capabilities.solver_cli calculate --input agent-beam-simple-uniform.calculate.json --pretty"
      },
      "mcp": {
        "tool": "calculate",
        "argumentsWrapper": "将 asmsJson 作为 arguments.payload 传入"
      },
      "benchmark": {
        "tool": "benchmark_case_run",
        "caseId": "beam-simply-supported-uniform",
        "purpose": "用同类简支梁均布荷载解析算例复核挠度峰值位置和支座数量。"
      },
      "export": {
        "endpoint": "/api/export",
        "format": "docx",
        "payloadOverlay": {
          "format": "docx"
        }
      },
      "acceptanceChecks": [
        "求解状态为 PASS。",
        "summary.maxDeflectionMm 大于 0。",
        "benchmark_case_run 返回 pass。",
        "计算书包含输入参数、计算方法说明、校核证据和公开验证集覆盖说明。"
      ]
    },
    {
      "id": "agent-frame-portal-lateral-load",
      "analysisType": "frame",
