        "tool": "calculate",
        "inputWrapper": "将 asmsJson 包装为 {\"payload\": asmsJson}",
        "command": "python -m backend.capabilities.solver_cli calculate --input agent-frame-portal-lateral-load.calculate.json --pretty"
