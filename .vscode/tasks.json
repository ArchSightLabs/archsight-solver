{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "清理后端调试端口",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/kill-ports.ps1",
                "-Ports",
                "6240"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "清理前端调试端口",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/kill-ports.ps1",
                "-Ports",
                "6241"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "清理全栈调试端口",
            "dependsOn": [
                "清理后端调试端口",
                "清理前端调试端口"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "前端 Vite HMR",
            "type": "shell",
            "command": "npm.cmd",
            "args": [
                "run",
                "dev",
                "--",
                "--host",
                "127.0.0.1",
                "--port",
                "6241",
                "--strictPort"
            ],
            "options": {
                "cwd": "${workspaceFolder}/frontend",
                "env": {
                    "BEAM_SOLVER_FRONTEND_HOST": "127.0.0.1",
                    "BEAM_SOLVER_FRONTEND_PORT": "6241",
                    "BEAM_SOLVER_BACKEND_TARGET": "http://127.0.0.1:6240"
                }
            },
            "dependsOn": "清理全栈调试端口",
            "dependsOrder": "sequence",
            "isBackground": true,
            "problemMatcher": {
                "owner": "vite",
                "pattern": [
                    {
                        "regexp": "^$"
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".+",
                    "endsPattern": ".*(ready in|Local:|http://127\\.0\\.0\\.1:6241|http://localhost:6241).*"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        }
    ]
}
