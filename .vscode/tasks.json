            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/kill-ports.ps1",
                "-Ports",
                "6241"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated",
                "clear": true,
                "close": true,
                "showReuseMessage": false
            }
        },
        {
            "label": "清理调试端口",
            "dependsOn": [
