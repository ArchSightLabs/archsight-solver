{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "清理后端端口",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/kill-ports.ps1",
                "-Ports",
                "6240"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated",
                "clear": true,
                "close": true,
                "showReuseMessage": false
            }
        },
        {
            "label": "清理前端端口",
            "type": "process",
